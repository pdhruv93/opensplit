# DATABASE_URL=postgresql://opensplit:opensplit@localhost:5432/opensplit

# MySQL (change provider in prisma/schema.prisma to "mysql")
# DATABASE_URL=mysql://opensplit:opensplit@localhost:3306/opensplit

API_PORT=3000
